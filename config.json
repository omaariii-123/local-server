{
  "servers": [
    {
      "host": "127.0.0.1",
      "ports": [8080, 8081, 8082],
      "isDefaultServer": true,
      "clientMaxBodySize": 10485760,
      "errorPages": {
        "404": "/var/www/errors/404.html",
        "403": "/var/www/errors/403.html",
        "500": "/var/www/errors/500.html"
      },
      "routes": [
        {
          "path": "/",
          "root": "/var/www/html",
          "acceptedMethods": ["GET", "POST"],
          "index": "index.html",
          "autoindex": false
        },
        {
          "path": "/downloads",
          "root": "/var/www/downloads",
          "acceptedMethods": ["GET"],
          "index": null,
          "autoindex": true
        },
        {
          "path": "/cgi-bin",
          "root": "/var/www/cgi-bin",
          "acceptedMethods": ["GET", "POST", "DELETE"],
          "cgi": {
            ".php": "/usr/bin/php-cgi",
            ".py": "/usr/bin/python3"
          }
        },
        {
          "path": "/old-blog",
          "redirection": {
            "code": 301,
            "url": "https://newblog.example.com"
          }
        }
      ]
    },
    {
      "host": "example.com",
      "ports": [80],
      "isDefaultServer": false,
      "clientMaxBodySize": 2048,
      "errorPages": {},
      "routes": [
        {
          "path": "/",
          "root": "/var/www/example",
          "acceptedMethods": ["GET"],
          "index": "home.html",
          "autoindex": false
        }
      ]
    }
  ]
}