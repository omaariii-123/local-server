    {
      "name": "03 · CGI Scripts — /api",
      "item": [
        {
          "name": "GET /api/index.py → 200 JSON",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Body is valid JSON', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j).to.have.property('status', 'ok');",
            "  pm.expect(j).to.have.property('method', 'GET');",
            "});"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Host", "value": "localhost:8080" }],
            "url": { "raw": "{{base_url}}/api/index.py", "host": ["{{base_url}}"], "path": ["api", "index.py"] }
          }
        },
        {
          "name": "GET /api/index.py?foo=bar&baz=1 — query string reflected",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Query params in response', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.query).to.have.property('foo', 'bar');",
            "  pm.expect(j.query).to.have.property('baz', '1');",
            "});"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Host", "value": "localhost:8080" }],
            "url": {
              "raw": "{{base_url}}/api/index.py?foo=bar&baz=1",
              "host": ["{{base_url}}"],
              "path": ["api", "index.py"],
              "query": [
                { "key": "foo", "value": "bar" },
                { "key": "baz", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "POST /api/index.py — form-urlencoded body → CGI 200 (not upload 201)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200 (CGI, not 201 upload)', () => pm.response.to.have.status(200));",
