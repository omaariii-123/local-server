    {
      "name": "04 · Sessions & Cookies",
      "item": [
        {
          "name": "First GET / — Set-Cookie issued (new session)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Set-Cookie header present', () => pm.response.to.have.header('Set-Cookie'));",
            "pm.test('Cookie contains session_id', () => {",
            "  pm.expect(pm.response.headers.get('Set-Cookie')).to.include('session_id');",
            "});",
            "pm.test('Cookie has HttpOnly flag', () => {",
            "  pm.expect(pm.response.headers.get('Set-Cookie')).to.include('HttpOnly');",
            "});",
            "const cookie = pm.response.headers.get('Set-Cookie');",
            "const match = cookie && cookie.match(/session_id=([^;]+)/);",
            "if (match) pm.collectionVariables.set('session_id', match[1]);"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Host", "value": "localhost:8080" }],
            "url": { "raw": "{{base_url}}/", "host": ["{{base_url}}"], "path": ["/"] }
          }
        },
        {
          "name": "Second GET / with valid session — no new Set-Cookie",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('No new Set-Cookie (session reused)', () => {",
            "  pm.expect(pm.response.headers.get('Set-Cookie')).to.be.null;",
            "});"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Host", "value": "localhost:8080" },
              { "key": "Cookie", "value": "session_id={{session_id}}" }
            ],
            "url": { "raw": "{{base_url}}/", "host": ["{{base_url}}"], "path": ["/"] }
          }
        },
        {
          "name": "GET / with fake session ID — new Set-Cookie issued",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Set-Cookie present for unknown session', () => {",
            "  pm.response.to.have.header('Set-Cookie');",
            "});"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Host", "value": "localhost:8080" },
              { "key": "Cookie", "value": "session_id=not-a-real-session-id-00000000" }
            ],
            "url": { "raw": "{{base_url}}/", "host": ["{{base_url}}"], "path": ["/"] }
          }
        }
      ]
    },

    {
      "name": "05 · Redirects",
      "item": [
        {
          "name": "GET /old-site → 301 Moved Permanently",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 301', () => pm.response.to.have.status(301));",
            "pm.test('Location header present', () => pm.response.to.have.header('Location'));",
            "pm.test('Location points to localhost root', () => {",
            "  pm.expect(pm.response.headers.get('Location')).to.include('localhost');",
            "});"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Host", "value": "localhost:8080" }],
            "url": { "raw": "{{base_url}}/old-site", "host": ["{{base_url}}"], "path": ["old-site"] }
          }
        },
        {
          "name": "GET /old-site — follow redirect → final 200",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Final status 200 after redirect', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Host", "value": "localhost:8080" }],
            "url": { "raw": "{{base_url}}/old-site", "host": ["{{base_url}}"], "path": ["old-site"] }
          },
          "protocolProfileBehavior": { "followRedirects": true }
        },
        {
          "name": "GET /old-site — do NOT follow redirect, check Location value",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 301', () => pm.response.to.have.status(301));",
            "pm.test('Location = http://localhost:8080/', () => {",
            "  pm.expect(pm.response.headers.get('Location')).to.eql('http://localhost:8080/');",
            "});"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Host", "value": "localhost:8080" }],
            "url": { "raw": "{{base_url}}/old-site", "host": ["{{base_url}}"], "path": ["old-site"] }
          },
          "protocolProfileBehavior": { "followRedirects": false }
        }
      ]
    },

